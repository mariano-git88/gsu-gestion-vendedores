# ===========================================
# Plantilla de secrets — Gestión de Vendedores GSU
# ===========================================
#
# Este archivo SÍ se commitea (es plantilla pública, sin secretos reales).
#
# Para correr el app LOCALMENTE:
#   1. Copiar este archivo a `.streamlit/secrets.toml` (sin .example)
#   2. Reemplazar los placeholders por los valores reales
#   3. Correr: streamlit run app.py
#
# Para PRODUCCIÓN (Streamlit Cloud):
#   - NO subir secrets.toml al repo (el .gitignore ya lo bloquea).
#   - En Streamlit Cloud → app → Settings → Secrets, pegar el mismo contenido
#     con los valores reales. Streamlit Cloud lo guarda encriptado at-rest.

# ---------- Autenticación del dashboard ----------
# Contraseña única compartida para entrar al app.
app_password = "cambiar_por_password_real_antes_de_correr"

# ---------- API de Contabilium ----------
# Credenciales para el modo primario de carga (pull automático contra
# la API REST de Contabilium UY, https://rest.contabilium.com.uy).
#
# Obtener los valores en:
#   - client_id: email admin de la cuenta Contabilium. En cuenta empresa
#     hija es el del usuario administrador (ver Mi Cuenta → Administrar
#     usuarios).
#   - client_secret: API Key generado en Contabilium en
#     Mi Cuenta → Datos de mi empresa → API.
#
# Requiere plan Full o superior. Si estos valores faltan o son inválidos,
# el dashboard muestra un error claro y queda disponible solo el
# "Modo Manual Secundario" (upload de xlsx).
contabilium_client_id = "email-admin@suprabond.com.uy"
contabilium_client_secret = "api-key-de-contabilium"
