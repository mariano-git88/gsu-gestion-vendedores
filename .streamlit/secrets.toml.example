# ===========================================
# Plantilla de secrets — Gestión de Vendedores GSU
# ===========================================
#
# Este archivo SÍ se commitea (es plantilla pública, sin secretos reales).
#
# Para correr el app LOCALMENTE:
#   1. Copiar este archivo a `.streamlit/secrets.toml` (sin .example)
#   2. Reemplazar los placeholders por los valores reales
#   3. Correr: streamlit run app.py
#
# Para PRODUCCIÓN (Streamlit Cloud):
#   - NO subir secrets.toml al repo (el .gitignore ya lo bloquea).
#   - En Streamlit Cloud → app → Settings → Secrets, pegar el mismo contenido
#     con los valores reales. Streamlit Cloud lo guarda encriptado at-rest.

# ---------- Autenticación del dashboard principal ----------
# Contraseña única compartida para entrar al app.py (Gestión de Vendedores).
app_password = "cambiar_por_password_real_antes_de_correr"

# ---------- API de Contabilium ----------
# Credenciales para el modo primario de carga (pull automático contra
# la API REST de Contabilium UY, https://rest.contabilium.com.uy).
#
# Obtener los valores en:
#   - client_id: email admin de la cuenta Contabilium. En cuenta empresa
#     hija es el del usuario administrador (ver Mi Cuenta → Administrar
#     usuarios).
#   - client_secret: API Key generado en Contabilium en
#     Mi Cuenta → Datos de mi empresa → API.
#
# Requiere plan Full o superior. Si estos valores faltan o son inválidos,
# el dashboard muestra un error claro y queda disponible solo el
# "Modo Manual Secundario" (upload de xlsx).
contabilium_client_id = "email-admin@suprabond.com.uy"
contabilium_client_secret = "api-key-de-contabilium"

# ---------- Asistente conversacional (tab 🤖 Asistente del dashboard) ----------
# API key de Anthropic (Claude). Obtener en https://console.anthropic.com.
# Costo típico: USD 0.005-0.02 por consulta. Para uso interno con 1-2
# usuarios, costo total mensual < USD 5. Si está vacía o falta, la tab
# muestra un error claro y el resto del dashboard funciona normal.
anthropic_api_key = "sk-ant-api03-..."

# ===========================================
# Lo de abajo SOLO aplica al segundo deploy de Streamlit Cloud que
# corre `comisiones_app.py` (Liquidación de Comisiones). El dashboard
# principal no lo necesita.
# ===========================================

# Password adicional para Comisiones (debe ser distinto del app_password).
comisiones_password = "cambiar_por_password_real_de_comisiones"

# ===========================================
# Lo de abajo SOLO aplica al tercer deploy de Streamlit Cloud que corre
# `facturador_app.py` (Facturación Masiva). El dashboard principal y el
# de Comisiones no lo necesitan.
# ===========================================

# Password adicional para Facturación Masiva. DEBE ser distinto de
# app_password y comisiones_password — este módulo escribe sobre el ERP
# (emisión de facturas con CAE), así que el círculo de acceso debería
# ser el más chico de los tres.
facturador_password = "cambiar_por_password_real_de_facturacion_masiva"

# ===========================================
# Lo de abajo SOLO aplica al cuarto deploy de Streamlit Cloud que corre
# `pedidos_app.py` (Carga de Pedidos — lectura y control de los pedidos
# que mandan los vendedores). Los otros tres no lo necesitan.
# ===========================================

# Password adicional para Carga de Pedidos. Debe ser distinto de los
# otros tres. Fase 1 es solo lectura de un Excel (no toca Contabilium),
# así que el círculo de acceso puede ser más amplio que el del facturador.
pedidos_password = "cambiar_por_password_real_de_carga_de_pedidos"

# ---------- Google Sheets — log de facturación masiva ----------
# Sheet propio del módulo de Facturación, separado del de Comisiones
# (separamos dominios). Tab dedicada `log_facturacion` que se crea sola
# en la primera escritura. Setup paso a paso: abrir el app del facturador
# y click "📖 Tutorial" en la sidebar.
#
# Reusa el MISMO Service Account que ya tenés para Comisiones —
# simplemente compartí el Sheet nuevo con el `client_email` del SA como
# Editor. Spreadsheet ID distinto, content del SA idéntico.
[gsheets_facturacion]
spreadsheet_id = "1XYZ...pegar_aca_el_id_del_sheet_de_facturacion"

# En LOCAL: apuntar al .json del SA en disco (mismo que Comisiones).
# service_account_json_path = ".gsheets/sa.json"

# En PRODUCCIÓN (Streamlit Cloud): pegar el contenido del JSON del SA
# embebido. Es IDÉNTICO al de [gsheets.service_account] del deploy de
# Comisiones — copiar/pegar y cambiar solo el header del bloque.
[gsheets_facturacion.service_account]
type = "service_account"
project_id = "tu-proyecto-gcp"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\nLINEAS_DEL_KEY\n-----END PRIVATE KEY-----\n"
client_email = "sa-name@tu-proyecto.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/sa-name%40tu-proyecto.iam.gserviceaccount.com"
universe_domain = "googleapis.com"

# ---------- Google Sheets (persistencia del histórico de Comisiones) ----------
# El histórico de comisiones vive en una Spreadsheet de Google. Acceso
# vía Service Account. Pasos para configurarlo: ver `gsheets.py` y
# el discovery de la sesión 12 en `_session-log.md`.
[gsheets]
spreadsheet_id = "1ABC...pegar_aca_el_id_del_sheet"

# En LOCAL podés usar un archivo JSON aparte (gitignored):
#     service_account_json_path = ".gsheets/sa.json"
# y omitir la sección [gsheets.service_account] de abajo.
#
# En PRODUCCIÓN (Streamlit Cloud) NO hay filesystem persistente, así que
# se pega el contenido del JSON acá como sub-section. Cada key del JSON
# va como una entrada TOML. Para generar este bloque a partir de un
# .json existente, usar la utility:
#     python3 _exploracion-api-contabilium/json_to_streamlit_secret.py .gsheets/sa.json

[gsheets.service_account]
type = "service_account"
project_id = "tu-proyecto-gcp"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\nLINEAS_DEL_KEY\n-----END PRIVATE KEY-----\n"
client_email = "sa-name@tu-proyecto.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/sa-name%40tu-proyecto.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
