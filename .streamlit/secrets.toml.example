# ===========================================
# Plantilla de secrets — Gestión de Vendedores GSU
# ===========================================
#
# Este archivo SÍ se commitea (es plantilla pública, sin secretos reales).
#
# Para correr el app LOCALMENTE:
#   1. Copiar este archivo a `.streamlit/secrets.toml` (sin .example)
#   2. Reemplazar el placeholder por la password real
#   3. Correr: streamlit run app.py
#
# Para PRODUCCIÓN (Streamlit Cloud):
#   - NO subir secrets.toml al repo (el .gitignore ya lo bloquea).
#   - En Streamlit Cloud → app → Settings → Secrets, pegar el mismo contenido
#     con la password real. Streamlit Cloud lo guarda encriptado at-rest.

app_password = "cambiar_por_password_real_antes_de_correr"
